<?php

use App\Services\Talkto\Commands\ExampleCommandSender;
use App\Services\Talkto\Commands\ExampleRecord;

test('source service can create an example outgoing command', function (): void {
    config([
        'app.env' => 'testing',
        'queue.default' => 'sync',
        'talkto.service' => '<source-service>',
    ]);

    $record = new ExampleRecord('example-123', 'ready');

    $message = app(ExampleCommandSender::class)->send($record);

    expect($message->target_service)->toBe('<destination-service>')
        ->and($message->command)->toBe('example:sync-record')
        ->and($message->idempotency_key)->toBe($record->idempotencyKey());
});
