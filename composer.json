{
    "name": "mrezdev/laravel-talkto",
    "description": "Reliable Laravel service-to-service messaging with signed outbox/inbox envelopes, idempotency, retries, callbacks, observability, and security audit tooling.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "webhook",
        "service-to-service",
        "hmac",
        "idempotency",
        "outbox",
        "inbox",
        "retry",
        "dead-letter",
        "callback",
        "observability",
        "security-audit"
    ],
    "authors": [
        {
            "name": "Laravel Talkto Maintainers",
            "role": "Maintainers"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/queue": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/validation": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "laravel/pint": "^1.29",
        "larastan/larastan": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Mrezdev\\LaravelTalkto\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mrezdev\\LaravelTalkto\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse",
        "format": "pint",
        "format:test": "pint --test",
        "check:audit": "composer audit",
        "check:composer": "composer validate --strict",
        "release:check": "composer validate --strict && composer audit && pint --test && phpstan analyse && pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mrezdev\\LaravelTalkto\\LaravelTalktoServiceProvider"
            ]
        }
    }
}
